{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "future-screen-danifest",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/client-log",
      "destination": "/api/client-log.ts"
    },
    {
      "source": "/api/send",
      "destination": "/api/send.ts"
    },
    {
      "source": "/((?!api|assets).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
