#!/usr/bin/env sh
# PR #7b: CODE_REVIEW H16 — prevent accidental commits of secrets or
# unlinted code reaching the remote. Two gates in order:
#   1. secrets scan (custom, no external binary) — fails loud if any
#      AWS/Google/Stripe/Slack/Supabase-looking key is staged
#   2. lint-staged — runs eslint --fix on staged TS/JS files
# Keep fast; this runs on every commit.

# Run secrets scan first — if someone stages a .env by mistake we want to
# abort BEFORE eslint touches anything.
node scripts/scan-secrets.mjs --staged || exit 1

npx --no-install lint-staged
